{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@odontogram-shell": ["src/modules/odontogram/odontogram-shell"],
      "@dq-importer": ["src/modules/dq-importer/src"],
      "@dq-importer/*": ["src/modules/dq-importer/src/*"],
      "@dq-calendar": ["src/modules/dq-calendar"],
      "@dq-calendar/*": ["src/modules/dq-calendar/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/modules/odontogram/engine", "src/modules/dq-importer/server", "src/modules/dq-importer/vite.config.ts"]
}
