{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@odontogram-shell": ["src/modules/odontogram/odontogram-shell"],
      "@flexi-importer": ["submodules/dq-flexi-importer/src"],
      "@flexi-importer/*": ["submodules/dq-flexi-importer/src/*"]
    }
  },
  "include": ["src", "submodules/dq-flexi-importer/src"],
  "exclude": ["src/modules/odontogram/engine"]
}
