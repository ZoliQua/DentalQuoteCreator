generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  male
  female
  other
}

enum UserRole {
  admin
  doctor
  assistant
  receptionist
  user
  beta_tester
}

model User {
  id           String                   @id
  email        String                   @unique
  fullName     String
  passwordHash String
  role         UserRole                 @default(user)
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  sessions            AuthSession[]
  permissionOverrides UserPermissionOverride[]
  auditTargets        PermissionAuditLog[] @relation("AuditTarget")
  auditChangers       PermissionAuditLog[] @relation("AuditChanger")
  activityLogs        UserActivityLog[]
  visitorLogs         VisitorLog[]
}

model AuthSession {
  id           String   @id
  userId       String
  tokenHash    String   @unique
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastSeenAt   DateTime @default(now())
  revokedAt    DateTime?
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserPermissionOverride {
  id         String   @id
  userId     String
  key        String
  isAllowed  Boolean
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([key])
}

model PermissionAuditLog {
  id              String   @id
  targetUserId    String
  changedByUserId String
  changedAt       DateTime @default(now())
  key             String
  oldValue        Boolean
  newValue        Boolean
  targetUser      User @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  changedByUser   User @relation("AuditChanger", fields: [changedByUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([changedAt])
}

model UserActivityLog {
  id         String   @id
  userId     String
  action     String
  page       String?
  entityType String?
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())
  ipAddress  String?
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Patient {
  patientId        String   @id
  title            String?
  lastName         String
  firstName        String
  sex              Sex
  birthDate        DateTime
  birthPlace       String?
  insuranceNum     String?
  phone            String?
  email            String?
  country          String?
  isForeignAddress Boolean  @default(false)
  zipCode          String?
  city             String?
  street           String?
  patientType      String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isArchived       Boolean  @default(false)
  createdByUserId  String?
  mothersName          String?
  neakDocumentType     Int      @default(1)
  patientVATName       String?
  patientVATNumber     String?
  patientVATAddress    String?
  patientDiscount      Int?
  isHungarianPhone     Boolean  @default(true)
  treatmentArchive     String?

  quotes       Quote[]
  snapshots    DentalStatusSnapshot[]
  appointments Appointment[]
  smsLogs      SmsLog[]
  emailLogs    EmailLog[]
}

model Quote {
  quoteId            String   @id
  patientId          String
  quoteStatus        String
  createdAt          DateTime @default(now())
  lastStatusChangeAt DateTime
  isDeleted          Boolean  @default(false)
  data               Json
  createdByUserId    String?
  quoteName          String?
  quoteNumber        String?
  validUntil         String?
  currency           String?
  doctorId           String?

  patient Patient @relation(fields: [patientId], references: [patientId])

  @@index([patientId])
}

model DentalStatusSnapshot {
  snapshotId String   @id
  patientId  String
  takenAt    DateTime
  note       String?
  teeth      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [patientId])

  @@index([patientId])
  @@index([takenAt])
}

model PriceList {
  priceListId     String  @id
  priceListNameHu String
  priceListNameEn String  @default("")
  priceListNameDe String  @default("")
  isActive        Boolean @default(true)
  isDeleted       Boolean @default(false)
  isDefault       Boolean @default(false)
  isNeak          Boolean @default(false)
  isUserLocked    Boolean @default(false)
  listOfUsers     Json    @default("[]")

  categories PriceListCategory[]
  items      PriceListCatalogItem[]
}

model PriceListCategory {
  catalogCategoryId     String  @id
  priceListId           String
  catalogCategoryPrefix String
  catalogCategoryHu     String
  catalogCategoryEn     String  @default("")
  catalogCategoryDe     String  @default("")
  isActive              Boolean @default(true)
  isDeleted             Boolean @default(false)

  priceList PriceList @relation(fields: [priceListId], references: [priceListId])
  items     PriceListCatalogItem[]

  @@index([priceListId])
}

model PriceListCatalogItem {
  catalogItemId         String  @id
  catalogCode           String
  catalogNameHu         String  @map("catalogName")
  catalogUnit           String
  catalogPrice          Float
  catalogPriceCurrency  String
  catalogVatRate        Float
  catalogTechnicalPrice Float
  catalogCategoryId     String
  priceListId           String?
  svgLayer              String  @default("")
  hasLayer              Boolean @default(false)
  hasTechnicalPrice     Boolean @default(false)
  isFullMouth           Boolean @default(false)
  isArch                Boolean @default(false)
  isQuadrant            Boolean @default(false)
  maxTeethPerArch       Int?
  allowedTeeth          Int[]   @default([])
  milkToothOnly         Boolean @default(false)
  catalogNameEn         String  @default("")
  catalogNameDe         String  @default("")
  isActive              Boolean @default(true)
  isDeleted             Boolean @default(false)

  priceList         PriceList?         @relation(fields: [priceListId], references: [priceListId])
  priceListCategory PriceListCategory @relation(fields: [catalogCategoryId], references: [catalogCategoryId])

  @@index([catalogCategoryId])
  @@index([priceListId])
}

model AppSettings {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model Invoice {
  id                     String   @id
  patientId              String
  quoteId                String
  status                 String
  createdAt              DateTime
  data                   Json
  createdByUserId        String?
  paymentMethod          String?
  fulfillmentDate        String?
  szamlazzInvoiceNumber  String?
  quoteNumber            String?
  invoiceType            String?

  @@index([patientId])
  @@index([quoteId])
}

model Doctor {
  doctorId        String   @id
  doctorName      String
  doctorNum       String   @default("")
  doctorEESZTId   String   @default("")
  createdAt       DateTime @default(now())
  createdByUserId String?
}

model NeakCheck {
  id              String   @id
  patientId       String
  taj             String?
  checkedAt       DateTime
  neakHibakod     String?
  neakSuccess     Boolean?
  neakJogviszony  String?
  neakTranKod     String?
  data            Json

  @@index([patientId])
  @@index([checkedAt])
  @@index([neakTranKod])
}

model OdontogramCurrent {
  patientId String   @id
  updatedAt DateTime
  data      Json
}

model OdontogramDaily {
  patientId String
  dateKey   String
  updatedAt DateTime
  data      Json

  @@id([patientId, dateKey])
  @@index([patientId])
}

model OdontogramTimeline {
  snapshotId String   @id
  patientId  String
  updatedAt  DateTime
  data       Json

  @@index([patientId])
  @@index([updatedAt])
}

model VisitorLog {
  id        String   @id
  userId    String?
  sessionId String?
  ipAddress String?
  userAgent String?
  browser   String?
  os        String?
  device    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
}

model InvoiceSettings {
  id                   String   @id @default("default")
  invoiceType          String   @default("paper")
  defaultComment       String   @default("")
  defaultVatRate       String   @default("TAM")
  defaultPaymentMethod String   @default("bankkártya")
  invoiceMode          String   @default("test")
  agentKeyLive         String   @default("")
  agentKeyTest         String   @default("")
  updatedAt            DateTime @updatedAt
}

model NeakDocumentType {
  neakDocumentId       String @id
  neakDocumentTypeCode Int
  neakDocumentDetails  String
}

model NeakLevel {
  neakLevelCode   String @id
  neakLevelInfoHu String
  neakLevelInfoEn String @default("")
  neakLevelInfoDe String @default("")
}

model NeakSpecial {
  neakSpecialMark     Int    @id
  neakSpecialMarkCode String @default("")
  neakSpecialDescHu   String
  neakSpecialDescEn   String @default("")
  neakSpecialDescDe   String @default("")
}

model NeakTerkat {
  neakTerKatCode   String @id
  neakTerKatInfoHu String
  neakTerKatInfoEn String @default("")
  neakTerKatInfoDe String @default("")
}

model NeakCatalogItem {
  neakCatalogItemId            String  @id
  neakCode                     String
  neakNameHu                   String
  neakNameEn                   String  @default("")
  neakNameDe                   String  @default("")
  catalogCategoryId            String
  neakPoints                   Int     @default(0)
  neakMinimumTimeMin           Int     @default(0)
  isFullMouth                  Boolean @default(false)
  isTooth                      Boolean @default(false)
  isArch                       Boolean @default(false)
  isQuadrant                   Boolean @default(false)
  isSurface                    Boolean @default(false)
  surfaceNum                   String  @default("")
  neakMaxQtyPerDay             Int?
  neakToothType                String  @default("")
  neakTimeLimitMonths          Int?
  neakTimeLimitDays            Int?
  neakTimeLimitQty             Int?
  neakTimeLimitSchoolStart     String  @default("")
  neakTimeLimitSchoolEnd       String  @default("")
  neakLevelA                   Boolean @default(false)
  neakLevelS                   Boolean @default(false)
  neakLevelT                   Boolean @default(false)
  neakLevelE                   Boolean @default(false)
  neakTerKatCodes              String  @default("")
  neakNotBillableWithCodes     String  @default("")
  neakNotBillableIfRecentCodes String  @default("")
  neakBillableWithCodes        String  @default("")
  neakSpecialMark              Int     @default(0)
  isActive                     Boolean @default(true)
  catalogUnit                  String  @default("db")
  milkToothOnly                Boolean @default(false)
  svgLayer                     String  @default("")
  hasLayer                     Boolean @default(false)
  isDeleted                    Boolean @default(false)

  @@index([neakCode])
  @@index([catalogCategoryId])
}

model NeakSettings {
  id                String   @id @default("default")
  dentalPraxisId    String   @default("DP001")
  neakOjoteKey      String   @default("")
  neakWssUser       String   @default("")
  neakWssPassword   String   @default("")
  updatedAt         DateTime @updatedAt
}

model NeakDepartment {
  id                        String   @id @default(cuid())
  dentalPraxisId            String   @default("DP001")
  neakDepartmentNameHu      String
  neakDepartmentNameEn      String   @default("")
  neakDepartmentNameDe      String   @default("")
  neakDepartmentCode        String
  neakDepartmentHours       Int
  neakDepartmentMaxPoints   Int
  neakDepartmentPrefix      String   @default("")
  neakDepartmentLevel       String   @default("A")
  neakDepartmentIndicator   String   @default("adult")
  updatedAt                 DateTime @updatedAt
}

model Country {
  countryId      Int    @id
  countryNameHu  String
  countryNameEn  String @default("")
  countryNameDe  String @default("")
}

model AppointmentChair {
  chairId     String   @id
  chairNr     Int
  chairNameHu String
  chairNameEn String   @default("")
  chairNameDe String   @default("")
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdBy   String?
}

model AppointmentType {
  typeId             String  @id
  nameHu             String
  nameEn             String  @default("")
  nameDe             String  @default("")
  color              String
  defaultDurationMin Int
  isSystem           Boolean @default(false)
  isActive           Boolean @default(true)
  sortOrder          Int     @default(0)

  appointments Appointment[]
}

model Appointment {
  appointmentId     String    @id
  patientId         String?
  chairIndex        Int       @default(0)
  startDateTime     DateTime
  endDateTime       DateTime
  title             String
  description       String?
  appointmentTypeId String?
  status            String    @default("scheduled")
  color             String?
  notes             String?
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdByUserId   String?
  googleEventId     String?
  googleCalendarId  String?  // Which Google calendar this event belongs to

  // Recurrence (RRULE / RFC 5545)
  recurrenceRule        String?
  recurrenceParentId    String?
  isRecurrenceException Boolean @default(false)

  patient            Patient?         @relation(fields: [patientId], references: [patientId])
  appointmentType    AppointmentType? @relation(fields: [appointmentTypeId], references: [typeId])
  recurrenceParent   Appointment?     @relation("RecurrenceInstances", fields: [recurrenceParentId], references: [appointmentId])
  recurrenceChildren Appointment[]    @relation("RecurrenceInstances")

  @@index([patientId])
  @@index([startDateTime])
  @@index([endDateTime])
  @@index([appointmentTypeId])
  @@index([status])
  @@index([recurrenceParentId])
}

model SmsSettings {
  id                String   @id @default("default")
  twilioAccountSid  String   @default("")
  twilioAuthToken   String   @default("")
  twilioPhoneNumber String   @default("")
  twilioWebhookUrl  String   @default("")
  isEnabled         Boolean  @default(false)
  clinicName        String   @default("")
  customTemplates   String   @default("[]")
  updatedAt         DateTime @updatedAt
}

model SmsLog {
  id           String   @id @default(cuid())
  twilioSid    String?
  toNumber     String
  fromNumber   String
  message      String
  templateId   String?
  status       String   @default("pending")
  patientId    String?
  patientName  String?
  context      String?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient      Patient? @relation(fields: [patientId], references: [patientId])

  @@index([patientId])
  @@index([twilioSid])
  @@index([status])
  @@index([createdAt])
}

model EmailSettings {
  id              String   @id @default("default")
  smtpHost        String   @default("")
  smtpPort        Int      @default(587)
  smtpSecure      Boolean  @default(false)
  smtpUser        String   @default("")
  smtpPass        String   @default("")
  fromEmail       String   @default("")
  fromName        String   @default("")
  isEnabled       Boolean  @default(false)
  clinicName      String   @default("")
  customTemplates String   @default("[]")
  updatedAt       DateTime @updatedAt
}

model GoogleCalendarSync {
  id              String   @id @default("default")
  clientId        String   @default("")
  clientSecret    String   @default("")
  redirectUri     String   @default("")
  accessToken     String   @default("")
  refreshToken    String   @default("")
  tokenExpiresAt  DateTime?
  isEnabled       Boolean  @default(false)
  syncMode        String   @default("bidirectional") // push | pull | bidirectional
  pollIntervalMin Int      @default(5)
  lastSyncAt      DateTime?
  syncToken       String?  // Google incremental sync token
  // Chair-to-calendar mapping: JSON array of { chairId, calendarId, calendarName }
  chairCalendarMap String  @default("[]")
  updatedAt       DateTime @updatedAt
}

model GoogleCalendarLog {
  id            String   @id @default(cuid())
  direction     String   // push | pull
  action        String   // create | update | delete | import
  appointmentId String?
  googleEventId String?
  chairId       String?
  calendarId    String?
  status        String   @default("success") // success | error
  errorMessage  String?
  details       String?  // JSON with extra info
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([appointmentId])
}

model EmailLog {
  id           String   @id @default(cuid())
  toEmail      String
  fromEmail    String
  subject      String
  body         String
  templateId   String?
  status       String   @default("pending")
  patientId    String?
  patientName  String?
  context      String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient      Patient? @relation(fields: [patientId], references: [patientId])

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
}
